{
  "name": "electron-di",
  "version": "1.3.5",
  "description": "Util para brindar tu aplicación de Electron hecha con npm create electron-vite la capacidad de inyectar dependecias y controladores de IPC",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "splitting": false,
    "sourcemap": true,
    "clean": true
  },
  "scripts": {
    "build": "tsup"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ajorgenmarten/electron-di.git"
  },
  "keywords": [
    "electron",
    "ipc",
    "decorators",
    "dependency injection"
  ],
  "author": "Alejandro Jorgen Marten",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.13.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "electron": ">=30.0.2 <32.0.0"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
